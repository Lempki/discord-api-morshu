# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required
DISCORD_API_SECRET=changeme

# Optional (defaults shown)

# Path to morshu.wav — mount via Docker volume or absolute path.
# TTS_SOURCE_WAV=/data/morshu.wav

# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# LOG_LEVEL=INFO

# Maximum text length for synthesis (characters).
# TTS_MAX_TEXT_LENGTH=500
