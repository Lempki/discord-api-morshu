# Required
DISCORD_API_SECRET=changeme

# Path to morshu.wav — mount via Docker volume or absolute path
TTS_SOURCE_WAV=/data/morshu.wav

# Optional
LOG_LEVEL=INFO
TTS_MAX_TEXT_LENGTH=500

# Path to a source MP4 file — reserved for future use, not required for any current feature.
# TTS_SOURCE_MP4=/data/morshu.mp4
